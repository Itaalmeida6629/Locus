### Configurações Globais
@baseUrl = http://localhost:3000
@contentType = application/json

### ----------------------------------------------------
### AUTENTICAÇÃO
### ----------------------------------------------------

# @name requisicaoLogin
# Realizar login para obter o token do administrador inicial
POST {{baseUrl}}/usuarios/login
Content-Type: {{contentType}}

{
    "email": "admin@locus.com",
    "senha_hash": "LocusAdmin"
}

### ----------------------------------------------------
### CONFIGURAÇÃO DO TOKEN AUTOMÁTICO
### ----------------------------------------------------

# Pega automaticamente o token retornado pela requisição acima
@token = {{requisicaoLogin.response.body.token}}


### ----------------------------------------------------
### ROTAS PÚBLICAS DE INSTITUIÇÕES (SUCESSO)
### ----------------------------------------------------

# Listar todas as instituições
GET {{baseUrl}}/instituicoes

###

# Buscar instituição por ID
GET {{baseUrl}}/instituicoes/1

###

# Buscar instituição por Nome
GET {{baseUrl}}/instituicoes/nome/Instituicao Padrao Locus

###

# Buscar instituições por Cidade
GET {{baseUrl}}/instituicoes/cidade/Sua Cidade


### ----------------------------------------------------
### ROTAS PROTEGIDAS (SUCESSO)
### ----------------------------------------------------

# Criar nova instituição
POST {{baseUrl}}/instituicoes
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nome": "Instituto Tecnológico Locus",
  "rua": "Avenida da Inovação",
  "numero": "500",
  "bairro": "Distrito Industrial",
  "cidade": "Porto Alegre",
  "estado": "RS",
  "cep": "90000000",
  "telefone": "5132109876"
}

###

# Atualizar dados da instituição
PUT {{baseUrl}}/instituicoes/2
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nome": "Instituto Locus - Nome Atualizado",
  "telefone": "51988887777"
}


### ----------------------------------------------------
### CENÁRIOS DE ERRO - INSTITUIÇÕES
### ----------------------------------------------------

# 1. Erro na Criação: Falta de Campo Obrigatório (Deve retornar 400 - "O campo 'cep' é obrigatório")
POST {{baseUrl}}/instituicoes
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nome": "Instituição Incompleta",
  "rua": "Rua Teste",
  "numero": "123",
  "bairro": "Centro",
  "cidade": "Garibaldi",
  "estado": "RS",
  "telefone": "5434620000"
}

###

# 2. Erro na Criação: Nome já cadastrado (Deve retornar 400 - "Instituição já cadastrada")
POST {{baseUrl}}/instituicoes
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nome": "Instituto Locus - Nome Atualizado",
  "rua": "Outra Rua",
  "numero": "10",
  "bairro": "Centro",
  "cidade": "Porto Alegre",
  "estado": "RS",
  "cep": "90000000",
  "telefone": "5132109876"
}

###

# 3. Erro na Criação: Campo com string vazia (Deve retornar 400 - "O campo 'nome' é obrigatório")
POST {{baseUrl}}/instituicoes
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "nome": "   ",
  "rua": "Avenida Central",
  "numero": "100",
  "bairro": "Centro",
  "cidade": "Bento Gonçalves",
  "estado": "RS",
  "cep": "95700000",
  "telefone": "5434510000"
}

###

# 4. Erro de Autenticação: Criar sem Token (Deve retornar 401 - "Token não fornecido")
POST {{baseUrl}}/instituicoes
Content-Type: {{contentType}}

{
  "nome": "Intruso Faculdade",
  "rua": "Rua Sem Acesso",
  "numero": "99",
  "bairro": "Invasão",
  "cidade": "Porto Alegre",
  "estado": "RS",
  "cep": "90000000",
  "telefone": "5100000000"
}

###

# 5. Erro de Busca: ID inexistente (Deve retornar 404 - "Instituição não encontrada")
GET {{baseUrl}}/instituicoes/999999


### ----------------------------------------------------
### DELEÇÃO 
### ----------------------------------------------------

# Deletar registro de instituição
DELETE {{baseUrl}}/instituicoes/2
Authorization: Bearer {{token}}